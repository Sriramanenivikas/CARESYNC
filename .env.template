# ==========================================
# CARESYNC Application - Environment Variables Template
# ==========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ==========================================

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=RestApi
DB_USERNAME=vikas
DB_PASSWORD=vikas123

# ==========================================
# EMAIL CONFIGURATION (for OTP and notifications)
# ==========================================
# Gmail Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@caresync.com

# Note: For Gmail, you need to:
# 1. Enable 2-Factor Authentication
# 2. Generate an App Password from Google Account settings
# 3. Use the App Password here (not your regular Gmail password)

# ==========================================
# SMS CONFIGURATION (for OTP)
# ==========================================
SMS_API_KEY=your-sms-api-key
SMS_API_SECRET=your-sms-api-secret
SMS_SENDER_ID=CARESYNC

# ==========================================
# JWT CONFIGURATION
# ==========================================
JWT_SECRET=87gbvdhcvs83cjsbOPnKnx#$%&*()@!~
JWT_EXPIRATION_MS=86400000

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
# Server Port (default: 2222 for DATAJPA module, 1111 for REST_API_s)
SERVER_PORT=2222

# Spring Profile (dev, test, prod)
SPRING_PROFILE=dev

# ==========================================
# SECURITY CONFIGURATION
# ==========================================
# Basic Auth Credentials (for development only)
SECURITY_USERNAME=vk
SECURITY_PASSWORD=vk123

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ==========================================
# FILE UPLOAD CONFIGURATION
# ==========================================
UPLOAD_DIR=/var/caresync/uploads
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
LOG_LEVEL=INFO
LOG_FILE_PATH=/var/log/caresync/application.log

# ==========================================
# FRONTEND CONFIGURATION (for React app)
# ==========================================
REACT_APP_API_BASE_URL=http://localhost:2222
REACT_APP_ENV=development
